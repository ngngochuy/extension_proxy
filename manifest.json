{
  "name": "Auth Proxy - Quick Proxy Switcher",
  "version": "1.3.0",
  "manifest_version": 3,
  "description": "Quickly enable/disable HTTP/HTTPS proxy with authentication. Manage proxy list, one-click switch, auto-detect IP.",
  "default_locale": "en",
  "permissions": [
    "proxy",
    "storage",
    "privacy",
    "webRequest",
    "webRequestAuthProvider",
    "declarativeNetRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "spoof-content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auth Proxy - Quick Proxy Switcher",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}